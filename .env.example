# Environment variables for local development and CI
# Replace placeholders with real values in your local `.env` or CI secrets.

# Backend / Database
DB_URL=jdbc:postgresql://localhost:5432/campus_connect
DB_USERNAME=postgres
DB_PASSWORD=change_me

# JWT
JWT_SECRET=replace_with_a_256bit_minimum_secret
JWT_EXPIRATION_MS=86400000

# Server
SERVER_PORT=8080

# CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
